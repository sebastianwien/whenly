# whenly — copy to .env and adjust before docker compose up

# Public base URL of the deployment. Used in share links, ICS URLs, OG metadata,
# and (for prod) as the CORS allow-list.
WHENLY_BASE_URL=http://localhost

# Host port nginx will bind to. The container always listens on 80 internally.
WHENLY_HOST_PORT=8080

# Database (postgres container).
WHENLY_DB_NAME=whenly
WHENLY_DB_USER=whenly
WHENLY_DB_PASSWORD=change-me-please

# Optional SMTP (off by default — emails are silently skipped if WHENLY_MAIL_ENABLED=false).
WHENLY_MAIL_ENABLED=false
WHENLY_MAIL_FROM=noreply@whenly.local
WHENLY_SMTP_HOST=
WHENLY_SMTP_PORT=587
WHENLY_SMTP_USER=
WHENLY_SMTP_PASSWORD=
